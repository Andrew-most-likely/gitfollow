# GitFollow configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Required
GH_TOKEN=your_github_personal_access_token_here
GH_USERNAME=your_github_username_here

# ── Follow behaviour ──────────────────────────────────────────────────────────
FOLLOW_LIMIT=150        # Max new follows per run (keep at/below 150/day)
UNFOLLOW_HOURS=24       # Hours to wait before unfollowing a non-reciprocator
WHITELIST=              # Comma-separated usernames to never unfollow
STATE_FILE=data/state.json

# ── Quality filters ───────────────────────────────────────────────────────────
ACTIVITY_DAYS=30        # Skip users inactive (no push) for this many days
MIN_FOLLOWERS=1         # Minimum follower count required
MAX_REPOS=500           # Skip accounts with more public repos than this
MAX_FF_RATIO=10.0       # Skip accounts whose following/followers ratio exceeds this
MIN_ACCOUNT_AGE_DAYS=30 # Skip accounts newer than this many days
CACHE_DAYS=7            # Days to cache quality-check results locally

# Note: changing quality filter values above (MIN_FOLLOWERS, ACTIVITY_DAYS, etc.)
# does NOT automatically invalidate cached results. Clear the cache from the
# Dashboard tab if you want all accounts re-evaluated immediately.

# ── Search pre-filters ────────────────────────────────────────────────────────
SEARCH_MIN_FOLLOWERS=10    # Pre-filter candidates by min followers in search query
SEARCH_MAX_FOLLOWERS=1000  # Pre-filter candidates by max followers in search query

# ── Quality unfollow (opt-in) ─────────────────────────────────────────────────
QUALITY_UNFOLLOW=false  # Set to "true" to also unfollow existing follows that
                        # fail quality criteria (inactive, orgs, follow-farmers)
