# GitFollow configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Required
GH_TOKEN=your_github_personal_access_token_here
GH_USERNAME=your_github_username_here

# Optional - defaults shown
FOLLOW_LIMIT=400
UNFOLLOW_HOURS=24
ACTIVITY_DAYS=30
MIN_FOLLOWERS=1
CACHE_DAYS=7
QUALITY_UNFOLLOW=false
WHITELIST=
